</statement>
<program interactive="activecode" language="java">
<code>
import java.util.Arrays;

public class SumOrSameGame
{
    private int[][] puzzle;
    
    /**
     * Identifies and clears an element of puzzle that can be paired with
     * the element at the given row and column, as described in part (b)
     * Preconditions: row and col are valid row and column indices in puzzle.
     * The element at the given row and column is between 1 and 9, inclusive.
     */
    public boolean clearPair(int row, int col)
    { 
        /* to be implemented in part (b) */ 

        
    }
    
    /* There may be instance variables, constructors,
    and methods that are not shown. */
    
    public static void main(String[] args)
    {
        int[][] p1 = {{0, 7, 9, 0}, {7, 4, 1, 6}, {8, 4, 1, 8}};
        
        SumOrSameGame g1 = new SumOrSameGame(p1);
        System.out.println(g1);
        System.out.println(g1.clearPair(0, 1));
        System.out.println(g1);
        System.out.println();
        
        int[][] p2 = {{1, 2, 3, 4}, {5, 6, 7, 8}, {5, 4, 1, 2}};
        
        g1 = new SumOrSameGame(p2);
        System.out.println(g1);
        System.out.println(g1.clearPair(2, 2));
        System.out.println(g1);
        System.out.println();
        
        int[][] p3 = {{8, 1, 0, 5}, {0, 4, 3, 6}, {3, 4, 5, 8}};
        
        g1 = new SumOrSameGame(p3);
        System.out.println(g1);
        System.out.println(g1.clearPair(1, 1));
        System.out.println(g1);
        System.out.println();
        
        int[][] p4 = {{1, 7, 9}, {2, 6, 5}, {4, 4, 4}};
        
        g1 = new SumOrSameGame(p4);
        System.out.println(g1);
        System.out.println(g1.clearPair(0, 2));
        System.out.println(g1);
        System.out.println();
    }
    
    public String toString() {
        return Arrays.deepToString(puzzle).replaceAll("], ", "\n").replaceAll(",","").replaceAll("\\[","").replaceAll("]",""); //replaceAll("\\[","\\{").replaceAll("\\]","\\}");
    }
    
    public int[][] getPuzzle() {
        return puzzle;
    }
    
    public SumOrSameGame(int[][] p) { 
        puzzle = p;
    }  
}
</code>
<tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;
import java.util.Arrays;

public class RunestoneTests extends CodeTestHelper
{
    @Test
    public void test00() {
        int[][] puz = {{3, 4, 4}, {8, 5, 9}, {8, 7, 6}};
        String res = "3 0 0\n8 5 9\n8 7 6";
        boolean ans = true;

        boolean passed = test(puz, res, ans, 0, 1);
        assertTrue(passed);        
    }

    @Test
    public void test01() {
        int[][] puz = {{1, 5, 4}, {4, 7, 6}, {4, 5, 5}};
        String res = "1 5 4\n0 7 0\n4 5 5";
        boolean ans = true;

        boolean passed = test(puz, res, ans, 1, 0);
        assertTrue(passed);        
    }

    @Test
    public void test02() {
        int[][] puz = {{6, 4, 8, 7}, {4, 4, 7, 9}, {5, 7, 10, 3}, {6, 9, 4, 1}};
        String res = "6 4 8 7\n0 0 7 9\n5 7 10 3\n6 9 4 1";
        boolean ans = true;

        boolean passed = test(puz, res, ans, 1, 1);
        assertTrue(passed);         
    }

    @Test
    public void test03() {
        int[][] puz = {{9, 3, 4, 9}, {5, 1, 3, 4}, {2, 9, 9, 9}, {1, 9, 3, 4}};
        String res = "9 3 4 9\n5 1 3 4\n2 9 9 9\n1 9 3 4";
        boolean ans = false;

        boolean passed = test(puz, res, ans, 2, 0);
        assertTrue(passed);          
    }

    @Test
    public void test04() {
        int[][] puz = {{6, 6, 8, 3, 1}, {10, 2, 9, 9, 5}, {8, 1, 5, 3, 3}};
        String res = "6 6 8 3 1\n10 2 9 9 5\n8 1 5 3 3";
        boolean ans = false;

        boolean passed = test(puz, res, ans, 2, 1);
        assertTrue(passed);      
    }

    private boolean test(int[][] puz, String res, boolean ans, int r, int c) {
        String desc = "Testing clearPair(" + r + ", " + c + ") on\n"+  toString(puz);
        String expected = ans + "\n" + res;
        String actual = "";
        boolean passed = false;

        try {
            SumOrSameGame d1 = new SumOrSameGame(puz);
            actual = d1.clearPair(r, c) + "\n";
            
            int[][] grid = d1.getPuzzle();
            actual += toString(grid);
            
            passed = expected.equals(actual);
        } catch (Exception e) {
            actual = "Code caused an error";
        }

        getResults(expected, actual, desc, passed);        
        return passed;
    }
    
    private String toString(int[][] puzzle)
    {
        return Arrays.deepToString(puzzle).replaceAll("], ", "\n").replaceAll(",","").replaceAll("\\[","").replaceAll("]",""); //replaceAll("\\[","\\{").replaceAll("\\]","\\}");
    }
}
</tests>
</program>
</activity>

