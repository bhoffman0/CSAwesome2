        int[] scores = {45, 15, 20, 35, 85, 65, 50, 80, 90, 60, 5, 20};
        int exp = 90;
        
        boolean passed = test(scores, exp);
        assertTrue(passed);
    }
    
    @Test
    public void test03() {
        int[] scores = {50, 20, 40, 15, 45, 25, 35, 55, 30, 95, 100, 75};
        
        int exp = 100;
        
        boolean passed = test(scores, exp);
        assertTrue(passed);
    }
    
    private boolean test(int[] scores, int exp) {
        Game g = new Game(scores);
        
        int result = g.playManyTimes(scores.length);
        
        boolean passed = result == exp;
        
        String desc = "Highest score for " + Arrays.toString(scores);
        
        getResults(""+exp, ""+result, desc, passed);        
        return passed;        
    }
}
</tests>
