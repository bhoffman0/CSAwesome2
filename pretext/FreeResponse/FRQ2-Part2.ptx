    <activity label="FRQ2-2025-SignedText">
      <statement>
        <p>Write the complete SignedText class. Your implementation must meet all specifications and conform to the examples in the table.</p>
      </statement>

      <program interactive="activecode" language="java">
        <code>
// Make sure you make the class header public

{
    // Private instance variables

    
    // Constructor


    // Methods



    // Do not change any code below this point

    public static void main(String[] args) 
    {
        SignedText st1 = new SignedText("", "Wong");
        String temp = st1.getSignature();
        System.out.println("Expecting Wong: " + temp);

        SignedText st2 = new SignedText("henri", "dubois");
        temp = st2.getSignature();
        System.out.println("Expecting h-dubois: " + temp);

        SignedText st3 = new SignedText("GRACE", "LOPEZ");
        temp = st3.getSignature();
        System.out.println("Expecting G-LOPEZ: " + temp);

        SignedText st4 = new SignedText("", "FOX");
        
        String text = "Dear";
        temp = st4.addSignature(text);
        System.out.println("Expecting DearFOX: " + temp);

        text = "Best wishesFOX";
        temp = st4.addSignature(text);
        System.out.println("Expecting Best wishesFOX: " + temp);

        text = "FOXThanks";
        temp = st4.addSignature(text);
        System.out.println("Expecting ThanksFOX: " + temp);
        
        text = "G-LOPEZHello";
        temp = st3.addSignature(text);
        System.out.println("Expecting HelloG-LOPEZ: " + temp);
    }
}
        </code>
        <tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;

public class RunestoneTests extends CodeTestHelper
{
    @Test
    public void test01()
    {
        String expected = "Wong";
        String actual = "";

        try {
            SignedText st = new SignedText("", "Wong");
            actual = st.getSignature();
        } catch (Exception e) {
            actual = "The code caused an exception";
        }

        boolean passed = getResults(expected, actual, "SignedText st = new SignedText(\"\", \"Wong\");\nst.getSignature();");
        assertTrue(passed);
    }
    
