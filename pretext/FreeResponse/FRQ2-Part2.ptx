    <activity label="FRQ2-2025-SignedText">
      <statement>
        <p>Write the complete SignedText class. Your implementation must meet all specifications and conform to the examples in the table.</p>
      </statement>

      <program interactive="activecode" language="java">
        <code>
// Make sure you make the class header public

{
    // Private instance variables

    
    // Constructor


    // Methods



    // Do not change any code below this point

    public static void main(String[] args) 
    {
        SignedText st1 = new SignedText("", "Wong");
        String temp = st1.getSignature();
        System.out.println("Expecting Wong: " + temp);

        SignedText st2 = new SignedText("henri", "dubois");
        temp = st2.getSignature();
        System.out.println("Expecting h-dubois: " + temp);

        SignedText st3 = new SignedText("GRACE", "LOPEZ");
        temp = st3.getSignature();
        System.out.println("Expecting G-LOPEZ: " + temp);

        SignedText st4 = new SignedText("", "FOX");
        
        String text = "Dear";
        temp = st4.addSignature(text);
        System.out.println("Expecting DearFOX: " + temp);

        text = "Best wishesFOX";
        temp = st4.addSignature(text);
        System.out.println("Expecting Best wishesFOX: " + temp);
    }
}
        </code>
        <tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;

public class RunestoneTests extends CodeTestHelper
{
    @Test
    public void test01()
    {
        String code = getCode();
        String expected = "class SignedText";
        boolean passed = code.contains(expected);

        String actual = "";
        String[] lines = code.split("\n");

        for (String line : lines) {
            if (line.contains("class") &amp;&amp; !line.contains("Main") &amp;&amp; !line.contains("Tester")){
                actual = line.trim();
                break;
            }
        }

        getResults(expected, actual, "Created SignedText class header correctly", passed);
        assertTrue(passed);
    }

    @Test
    public void test02()
    {
        String code = getCode();
        String[] lines = code.split("\n");

        int str = countVariables(lines, "private String");

        String expected = "private String: 2";
        String actual = "private String: " + str;

        boolean passed = str &gt;= 2;
        getResults(expected, actual, "Created two private instance String variables", passed);
        assertTrue(passed);
    }

    @Test
    public void test03()
    {
        String code = getCode();
        String[] lines = code.split("\n");

        String expect = "public SignedText(...)";
        String actual = "";

        for (String line : lines) {
            if(stringMatch(line, "SignedText(") &amp;&amp; !line.contains("new")) {
                actual += line.trim() + "\n";
            }
        }

        boolean passed = actual.contains(",") &amp;&amp; countOccurences(actual, "String") == 2;
        getResults(expect, actual, "Constructor header with two parameters", passed);
        assertTrue(passed);
    }

    @Test
    public void test04()
    {
        String code = getCode();
        String[] lines = code.split("\n");

        String expect = "firstName = first;\nlastName = last;";
        String actual = "";

        boolean start = false;

        for (String line : lines) {
            if(stringMatch(line, "SignedText(")) {
                start = true;   
            } else if (start &amp;&amp; line.contains("=")) {
                actual += line.trim() + "\n";
            } else if (start &amp;&amp; line.contains("}")) {
                break;
            }
        }

        boolean passed = countOccurences(actual, "=") == 2;
        getResults(expect, actual, "Constructor sets both variables to values", passed);
        assertTrue(passed);
    }

    @Test
    public void test05()
    {
        String code = getCode();
        String[] lines = code.split("\n");

        String expect = "String getSignature()\nString addSignature(String ...)";
        String actual = "";

        for (String line : lines) {
            if(stringMatch(line, "String getSignature()") || stringMatch(line, "String addSignature(")) {
                actual += line.trim() + "\n";
            }
        }

        boolean passed = actual.split("\n").length == 2 &amp;&amp; countOccurences(actual, "String") == 3;
        getResults(expect, actual, "Method headers with correct return types and parameters", passed);
        assertTrue(passed);
    }

    @Test
    public void test06()
    {
        String code = getCode();
        code = getMethodCode(code, "String getSignature()");
        String[] lines = code.split("\n");

        String expect = "firstname.equals(\"\")";
        String actual = "";

        for (String line : lines) {
            if(stringMatch(line, ".equals") || stringMatch(line, "==")) {
                actual += line.trim() + "\n";
            }
        }

        boolean passed = actual.length() > 0 &amp;&amp; actual.contains("\"\"");
        getResults(expect, actual, "Compares first name to the empty string", passed);
        assertTrue(passed);
    }

    @Test
    public void test07()
    {
        String code = getCode();

        code = getMethodCode(code, "String addSignature(");

        int numReturns = countOccurences(code, "return");

        String[] lines = code.split("\n");

        String expect = "if (index == -1)\nelse if (index == 0)\nelse";
        String actual = "";

        for (String line : lines) {
            if(stringMatch(line, "if") || stringMatch(line, "else")) {
                actual += line.trim() + "\n";
            }
        }

        boolean passed = actual.split("\n").length >= 2 &amp;&amp; stringMatch(actual, "==0") &amp;&amp; numReturns == 3;
        getResults(expect, actual, "Identifies the three required cases for addSignature using appropriate conditions", passed);
        assertTrue(passed);
    }

    @Test
    public void test08()
    {
        String code = getCode();

        code = getMethodCode(code, "String addSignature(");

        String[] lines = code.split("\n");

        String expect = ".indexOf(...)\n.length()\n.substring(...)";
        String actual = "";

        for (String line : lines) {
            if(stringMatch(line, "indexOf") || stringMatch(line, "length") || stringMatch(line, "contains") || stringMatch(line, "substring")) {
                actual += line.trim() + "\n";
            }
        }

        boolean passed = actual.split("\n").length >= 2;
        getResults(expect, actual, "Uses String methods", passed);
        assertTrue(passed);
    }
    
    @Test
    public void test09()
    {
        String code = getCode();

        code = getMethodCode(code, "String addSignature(");

        String[] lines = code.split("\n");

        String expect = "return textStr + sig;\nreturn textStr.substring(sig.length()) + sig;\nreturn textStr;";
        String actual = "";

        for (String line : lines) {
            if(stringMatch(line, "return")) {
                actual += line.trim() + "\n";
            }
        }

        boolean passed = actual.split("\n").length &gt;= 3;
        getResults(expect, actual, "Returns three different cases", passed);
        assertTrue(passed);
    }

    @Test
    public void test10()
    {
        String output = "No output detected";
        String expect = "Expecting Wong: Wong\nExpecting h-dubois: h-dubois\n"
            + "Expecting G-LOPEZ: G-LOPEZ\nExpecting DearFOX: DearFOX\n"
            + "Expecting Best wishesFOX: Best wishesFOX";

        try {
            output = getMethodOutput("main");

            boolean passed = stringMatch(output, expect);
            getResults(expect, output, "Main method produces proper output", passed);
            assertTrue(passed);
        } catch (Exception e) {
            getResults(expect, output, "Main method produces proper output", false);
            assertTrue(false);
        }
    }

    private String getMethodCode(String code, String name) {
        String searchStr = code;
        int start = searchStr.indexOf(name);
        searchStr = searchStr.substring(start);

        int level = 0;

        for (int i = 0; i &lt; searchStr.length(); i++) {
            if (searchStr.substring(i,i+1).equals("{")) {
                level++;
            } else if (searchStr.substring(i,i+1).equals("}")) {
                level--;

                if (level == 0) {
                    //System.out.println(searchStr.substring(0, i+1).trim());
                    return searchStr.substring(0, i+1).trim();
                }
            }
        }

        return searchStr.trim();
    }

    private boolean stringMatch(String str1, String str2) {
        str1 = str1.replaceAll("\\s+", "");
        str2 = str2.replaceAll("\\s+", "");

        return str1.contains(str2);
    }

    private int countVariables(String[] lines, String type) {
        int num = 0;
        for (String line : lines){
            if (line.contains(type)) {
                if (line.contains(",")) {
                    num += line.split(",").length;
                } else {
                    num++;
                }
            }
        }
        return num;
    }
}
        </tests>
      </program>
    </activity>
