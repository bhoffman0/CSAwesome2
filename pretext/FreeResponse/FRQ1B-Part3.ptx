    private boolean test(int i) {
        String desc = "countValidDoublets(\"" + input1[i] + "\", \"" + input2[i] + "\")";
        String actual = "";

        try {
            actual = "" + SequenceAnalyzer.countValidDoublets(input1[i], input2[i]);
        } catch (Exception e) {
            actual = "test experienced an error";
        }

        boolean passed = getResults(expected[i],actual,desc);
