<activity label="frq1b3-TextExpander">
<statement>
<p>A software company is creating a "Short-Hand Expander" that converts common abbreviations into their full-word equivalents. You will write a method for the TextExpander class that finds and replaces specific abbreviations.</p>
<p>Write the method expandText, which takes three String parameters: message, abbr, and fullWord. The method should return a new String where every occurrence of the abbreviation abbr in message is replaced by fullWord.</p>
</statement>

<program interactive="activecode" language="java">
<code>
public class TextExpander
{
    /**
     * Returns a version of message where every instance of abbr 
     * is replaced by fullWord.
     * Precondition: message, abbr, and fullWord are not null.
     */
    public static String expandText(String message, String abbr, String fullWord) 
    {
        
    }

    public static void main(String[] args) {
        // Test 1: Standard replacement
        String m1 = "See you l8r!";
        System.out.println("Input: " + m1);
        System.out.println("Result: " + expandText(m1, "l8r", "later"));
        System.out.println();

        // Test 2: Multiple occurrences
        String m2 = "u should call u-r mom";
        System.out.println("Input: " + m2);
        System.out.println("Result: " + expandText(m2, "u", "you"));
        System.out.println();

        // Test 3: Abbreviation not found
        String m3 = "Hello world";
        System.out.println("Input: " + m3);
        System.out.println("Result: " + expandText(m3, "bye", "goodbye"));
    }
}
</code>
<tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;

public class RunestoneTests extends CodeTestHelper
{
    private String[] input1 = {"asap please", "Call me asap", "aaaaa", "JK...JK", "100%"};
    private String[] input2 = {"asap", "asap", "aa", "JK", "100"};
    private String[] input3 = {"as soon as possible", "soon", "b", "Just Kidding", "One Hundred"};
    private String[] expected = {"as soon as possible please", "Call me soon", "bba", "Just Kidding...Just Kidding", "One Hundred%"};

    @Test
    public void test0() {
        boolean passed = test(0);
        assertTrue(passed);
    }

    @Test
    public void test1() {
        boolean passed = test(1);
        assertTrue(passed);
    }

    @Test
    public void test2() {
        boolean passed = test(2);
        assertTrue(passed);
    }

    @Test
    public void test3() {
        boolean passed = test(3);
        assertTrue(passed);
    }

    @Test
    public void test4() {
        boolean passed = test(4);
        assertTrue(passed);
    }

    private boolean test(int i) {
        String desc = "expandText(\"" + input1[i] + "\", \"" + input2[i] + "\"" + input3[i] + "\")";
        String actual = "";

        try {
            actual = "" + TextExpander.expandText(input1[i], input2[i], input3[i]);
        } catch (Exception e) {
            actual = "test experienced an error";
        }

        boolean passed = getResults(expected[i],actual,desc);
        return passed;        
    }

    private boolean stringMatch(String str1, String str2) {
        str1 = str1.replaceAll(" ", "");
        str2 = str2.replaceAll(" ", "");

        return str1.contains(str2);
    }
}
