<activity label="frq1a-2025-dogwalker-a">
<statement>
<p>
Complete method <c>walkDogs</c>. You must use <c>numAvailableDogs</c> and <c>updateDogs</c> appropriately to receive full credit.
</p>
</statement>
<program interactive="activecode" language="java">
<code>
public class DogWalker
{
    /** The maximum number of dogs this walker can walk simultaneously
    per hour */
    private int maxDogs;

    /** The dog-walking company this dog walker is associated with */
    private DogWalkCompany company;

    /**
        * Takes at least one dog for a walk during the time specified by
        * hour, as described in part (a)
        * Preconditions: 0 &lt;= hour &lt;= 23
        * maxDogs &gt; 0
        */
    public int walkDogs(int hour)
    { 
        /* to be implemented in part (a) */ 
        return -1;
    }

    /* Do not change anything below this comment */

    /**
        * Assigns max to maxDogs and comp to company
        * Precondition: max &gt; 0
        */
    public DogWalker(int max, DogWalkCompany comp)
    {
        maxDogs = max;
        company = comp;
    }

    public static void main(String[] args) {
        DogWalkCompany comp = new DogWalkCompany();
        
        DogWalker walker1 = new DogWalker(3, comp);
        DogWalker walker2 = new DogWalker(4, comp);
        DogWalker walker3 = new DogWalker(5, comp);
        
        int resultsA1 = walker1.walkDogs(1);
        int resultsA2 = walker2.walkDogs(0);
        int resultsA3 = walker3.walkDogs(2);
        
        System.out.println("Walker 1 (max of 3) should walk 3 dogs: " + resultsA1);
        System.out.println("Company should now have 6 dogs: " + comp.numAvailableDogs(0));
        System.out.println("Walker 2 (max of 4) should walk 4 dogs: " + resultsA2);
        System.out.println("Company should now have 0 dogs: " + comp.numAvailableDogs(1));
        System.out.println("Walker 3 (max of 5) should walk 2 dogs: " + resultsA3);
        System.out.println("Company should now have 0 dogs: " + comp.numAvailableDogs(2));
    }
}

class DogWalkCompany
{
    private int[] dogs;

    public DogWalkCompany() {
        dogs = new int[] {10, 3, 2, 2, 1, 5, 4, 3, 2, 2, 3, 1, 5, 4, 5, 2, 5, 3, 2, 1, 3, 3, 1, 5};
    }

    /**
        * Returns the number of dogs, always greater than 0, that are available
        * for a walk during the time specified by hour
        * Preconditions: 0 &lt;= hour &lt;= 23
        */
    public int numAvailableDogs(int hour)
    { return dogs[hour]; }

    /**
        * Decreases, by numberDogsWalked, the number of dogs available for a walk
        * during the time specified by hour
        * Preconditions: 0 &lt;= hour &lt;= 23
        * numberDogsWalked &gt; 0
        */
    public void updateDogs(int hour, int numberDogsWalked)
    { dogs[hour] -= numberDogsWalked; }

    /* There may be instance variables, constructors,
    and methods that are not shown. */
}

</code>
<tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;

public class RunestoneTests extends CodeTestHelper
{
    @Test
    public void test01() {
        boolean passed = testPartA(4, 0, 4, 6);
        assertTrue(passed);        
    }

    @Test
    public void test02() {
        boolean passed = testPartA(2, 1, 2, 1);
        assertTrue(passed);        
    }

    @Test
    public void test03() {
        boolean passed = testPartA(5, 3, 2, 0);
        assertTrue(passed);        
    }

    @Test
    public void test04() {
        boolean passed = testPartA(1, 2, 1, 1);
        assertTrue(passed);        
    }

    @Test
    public void test05() {
        boolean passed = testPartA(0, 4, 0, 1);
        assertTrue(passed);        
    }

    private boolean testPartA(int max, int hour, int exp, int remain) {
        DogWalkCompany comp = new DogWalkCompany();
        DogWalker walker = new DogWalker(max, comp);
        
        int result = walker.walkDogs(hour);
        
        int left = comp.numAvailableDogs(hour);
        
        boolean passed = result == exp &amp;&amp; left == remain;
        
        String desc = "Walker (max of " + max + ") should walk " + exp + " dogs\n";
        desc += "Company should now have " + remain + " dogs: " + left;
        
        getResults(""+exp, ""+result, desc, passed);        
        return passed;
    }
}     
</tests>
</program>
</activity>


