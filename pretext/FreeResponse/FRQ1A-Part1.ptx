        boolean passed = getResults("" + expect, "" + answer, "dayOfWeek(7, 2, 2020)");
        assertTrue(passed);
    }

    @Test
    public void test3()
    {
        int answer = APCalendar.dayOfWeek(2, 29, 2022);
