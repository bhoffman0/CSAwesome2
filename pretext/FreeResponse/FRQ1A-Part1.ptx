              <activity label="FRQ-2022-Game-Score-Part0">
      <statement>
        <p>
          Complete the getScore method below. The score is calculated by adding the points from each level, but in this version, level 2 points are doubled, and level 3 points are tripled. 
        </p>
      </statement>

      <program interactive="activecode" language="java">
        <code>
            public class Game
{
    private Level levelOne, levelTwo, levelThree;

    public int getScore()
    {
        /* write your code here */
        return -1;
    }

    /* Don't change any code after this comment */

    public static void main(String[] args)
    {
        Level levelOne = new Level(100, true);
        Level levelTwo = new Level(100, true);
        Level levelThree = new Level(200, true);

        Game game = new Game(levelOne, levelTwo, levelThree);
        System.out.println("The score is: " + game.getScore());
    }

    public Game(Level level1, Level level2, Level level3)
    {
        levelOne = level1;
        levelTwo = level2;
        levelThree = level3;
    }

}

/* The Level class: do not change */
class Level
{
    private int points;
    private boolean goal;

    /** Constructor for the Level class */
    public Level(int p, boolean g)
    {
        points = p;
        goal = g;
    }

    /** Returns true if the player reached the goal on this level and returns false otherwise */
    public boolean goalReached()
    { return goal; }

    /** Returns the number of points recorded for this level */
    public int getPoints()
    { return points; }
}

          </code>
          <tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;
import java.util.Arrays;
import java.util.ArrayList;

public class RunestoneTests extends CodeTestHelper
{
    @Test
    public void test00() {
        String code = getCode();
        code = code.substring(0, code.indexOf("class Level"));
        int count = countOccurences(code, ".getPoints()");
        
        String desc = "Calls to .getPoints()";
        
        boolean passed = getResults(""+3, ""+count, desc);
        assertTrue(passed);
    }
    
    @Test
    public void test01() {
        Level l1 = new Level(100, true);
        Level l2 = new Level(100, true);
        Level l3 = new Level(200, true);
        
        int exp = 100 + 200 + 3 * 200;
        
        boolean passed = test(l1, l2, l3, exp);
        assertTrue(passed);
    }
    
    @Test
    public void test02() {
        Level l1 = new Level(100, true);
        Level l2 = new Level(200, true);
        Level l3 = new Level(300, true);
        
        int exp = 100 + 2 * 200 + 3 * 300;
        
        boolean passed = test(l1, l2, l3, exp);
        assertTrue(passed);
    }
    
    @Test
    public void test03() {
        Level l1 = new Level(300, true);
        Level l2 = new Level(200, true);
        Level l3 = new Level(100, true);
        
        int exp = 300 + 2 * 200 + 3 * 100;
        
        boolean passed = test(l1, l2, l3, exp);
        assertTrue(passed);
    }
    
    private boolean test(Level l1, Level l2, Level l3, int exp) {
        Game g = new Game(l1, l2, l3);
        
        int result = g.getScore();
        
        boolean passed = result == exp;
        
        String desc = "Final score for " + l1.getPoints() + ", " + l2.getPoints() + ", and " + l3.getPoints();
        
        getResults(""+exp, ""+result, desc, passed);        
        return passed;        
    }
}
          </tests>
            </program>
        </activity>



    </subsection>

    <subsection xml:id="calling-static-methods">
    <title>Calling Static Methods</title>
        <p>Some methods are static methods and should be called using the class name instead of an object.</p>
        <p>Math methods are static methods:</p>
        <ul>
            <li>
                <p>
                    <c>Math.random()</c>
                </p>
            </li>
            <li>
                <p>
                    <c>Math.pow(x, y)</c>
                </p>
            </li>
            <li>
                <p>
                    <c>Math.abs(x)</c>
                </p>
            </li>
        </ul>

    </subsection>
</section>
