<subsection xml:id="FRQ2-2018-CodeWordChecker">
<title>2018 FRQ 2 - CodeWordChecker</title>

<p>
<term>Question 2.</term> 
This question involves writing a CodeWordChecker class.
(This question originally appeared as Question 3 and was written slightly differently. It has been updated to match the new content and test format.)
</p>

<p>
A CodeWordChecker object can be constructed with
three parameters: two integers and a string. The first two parameters specify the minimum and maximum code
word lengths, respectively, and the third parameter specifies a string that must not occur in the code word.
A CodeWordChecker object can also be constructed with a single parameter that specifies a string that must
not occur in the code word; in this case the minimum and maximum lengths will default to 6 and 20,
respectively.
</p>
<p>The following examples illustrate the behavior of CodeWordChecker objects.</p>
<p>Example 1</p>
<p><c>StringChecker sc1 = new CodeWordChecker(5, 8, "$");</c></p>
<p>Valid code words have 5 to 8 characters and must not include the string "$". </p>

<p>Example 2</p>
<p><c>StringChecker sc2 = new CodeWordChecker("pass");</c></p>
<p>
Valid code words must not include the string "pass". Because the bounds are not specified, the length
bounds are 6 and 20, inclusive. 
</p>

<activity label="frq2018-wordchecker">
<statement>
<p>
Write the complete <c>CodeWordChecker</c> class. Your implementation must meet all specifications and
conform to all examples.
</p>
</statement>
<program interactive="activecode" language="java">
<code>
/* class header */

{
    /* instance variables */
    
    /* constructor(s) */
    
    /* method(s) */

    
    /* do not change this code */
    public static void main(String[] args)
    {
        CodeWordChecker sc1 = new CodeWordChecker(5, 8, "$");
        System.out.println("sc1.isValid(\"happy\") should be true: " + sc1.isValid("happy"));
        System.out.println("sc1.isValid(\"happy$\") should be false: " + sc1.isValid("happy$"));
        System.out.println("sc1.isValid(\"Code\") should be false: " + sc1.isValid("Code"));
        System.out.println("sc1.isValid(\"happyCode\") should be false: " + sc1.isValid("happyCode"));
        
        CodeWordChecker sc2 = new CodeWordChecker("pass");
        System.out.println("sc2.isValid(\"MyPass\") should be true: " + sc2.isValid("MyPass"));
        System.out.println("sc2.isValid(\"Mypassport\") should be false: " + sc2.isValid("Mypassport"));
        System.out.println("sc2.isValid(\"happy\") should be true: " + sc2.isValid("happy"));
        System.out.println("sc2.isValid(\"1,000,000,000,000,000\") should be true: " + sc2.isValid("1,000,000,000,000,000"));
    }
}
</code>
<tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;
import java.util.Arrays;

public class RunestoneTests extends CodeTestHelper
{
    @Test
    public void test00() {
        boolean passed = testA(5, 8, "$", "happy", true);
        assertTrue(passed);        
    }

    @Test
    public void test01() {
        boolean passed = testA(6, 8, "$", "happy", false);
        assertTrue(passed);       
    }

    @Test
    public void test02() {
        boolean passed = testA(5, 8, "$", "happy$", false);
        assertTrue(passed);       
    }

    @Test
    public void test03() {
        boolean passed = testA(5, 8, "$", "happyhappy", false);
        assertTrue(passed);        
    }

    @Test
    public void test04() {
        boolean passed = testA(5, 8, "$$$", "happy$$$", false);
        assertTrue(passed);        
    }

    private boolean testA(int min, int max, String symbol, String test, boolean exp) {
        String desc = "sc1.isValid(\"" + test + "\") for length " + min + "-" + max + " and symbol " + symbol;
        String expected = "" + exp;
        String actual = "";
        boolean passed = false;
        
        try {
           CodeWordChecker sc1 = new CodeWordChecker(min, max, symbol);
           actual += sc1.isValid(test);  
        } catch (Exception e) {
            actual = "Code caused an error";
        }

        passed = getResults(expected, actual, desc);        
        return passed;
    }
    
    @Test
    public void test05() {
        boolean passed = testB("$", "happy", false);
        assertTrue(passed);        
    }
    
    @Test
    public void test06() {
        boolean passed = testB("$", "happyhappy", true);
        assertTrue(passed);        
    }
    
    @Test
    public void test07() {
        boolean passed = testB("$", "happy$", false);
        assertTrue(passed);        
    }
    
    @Test
    public void test08() {
        boolean passed = testB("$$$", "happy$", true);
        assertTrue(passed);        
    }
    
    @Test
    public void test09() {
        boolean passed = testB("$$$", "happy$$$", false);
        assertTrue(passed);        
    }
    
    private boolean testB(String symbol, String test, boolean exp) {
        String desc = "sc2.isValid(\"" + test + "\") for default length and symbol " + symbol;
        String expected = "" + exp;
        String actual = "";
        boolean passed = false;
        
        try {
           CodeWordChecker sc1 = new CodeWordChecker(symbol);
           actual += sc1.isValid(test);  
        } catch (Exception e) {
            actual = "Code caused an error";
        }

        passed = getResults(expected, actual, desc);        
        return passed;
    }
}
</tests>
</program>
</activity>
</subsection>


<subsection xml:id="FRQ3-2018-WordPair-A">
<title>2018 FRQ 3 - WordPair - A</title>
<p>
<term>Question 3.</term> 
This question involves reasoning about pairs of words that are represented by the following 
WordPair class. (This question originally appeared as Question 2. It has been updated to match the new test format.)
</p>

<program language="java">
<code>
public class WordPair
{
    /** Constructs a WordPair object. */
    public WordPair(String first, String second)
    { /* implementation not shown */ }

    /** Returns the first string of this WordPair object. */
    public String getFirst()
    { /* implementation not shown */ }
    
    /** Returns the second string of this WordPair object. */
    public String getSecond()
    { /* implementation not shown */ }
}
</code>
</program>

<p>
You will implement the constructor and another method for the following WordPairList class.
</p>

<program language="java">
<code>
public class WordPairList
{
    /** The list of word pairs, initialized by the constructor. */
    private ArrayList&lt;WordPair&gt; allPairs;
    
    /** Constructs a WordPairList object as described in part (a).
    * Precondition: words.length &gt;= 2
    */
    public WordPairList(String[] words)
    { /* to be implemented in part (a) */ }
    
    /** Returns the number of matches as described in part (b).
    */
    public int numMatches()
    { /* to be implemented in part (b) */ }
}
</code>
</program>
<p>
<term>Part (a)</term>
Write the constructor for the <c>WordPairList</c> class. The constructor takes an array of strings words as
a parameter and initializes the instance variable <c>allPairs</c> to an <c>ArrayList</c> of <c>WordPair</c> objects.
</p>

<p>
A WordPair object consists of a word from the array paired with a word that appears later in the array.
The allPairs list contains WordPair objects (words[i], words[j]) for every i and j,
where 0 &lt;= i &lt; j &lt; words.length . Each WordPair object is added exactly once to the list. 
</p>
<p>
The following examples illustrate two different WordPairList objects.
</p>
<p>
Example 1    
</p>
<p>
<c>
String[] wordNums = {"one", "two", "three"};
WordPairList exampleOne = new WordPairList(wordNums);
</c>
</p>
<p>
After the code segment has executed, the allPairs instance variable of exampleOne will contain
the following WordPair objects in some order.    
</p>
<p>
<c>
("one", "two"), ("one", "three"), ("two", "three")
</c>
</p>
<p>
Example 2    
</p>
<p>
<c>
String[] phrase = {"the", "more", "the", "merrier"};
WordPairList exampleTwo = new WordPairList(phrase);
</c>
</p>
<p>
After the code segment has executed, the allPairs instance variable of exampleTwo will contain
the following WordPair objects in some order.   
</p>
<p>
<c>
("the", "more"), ("the", "the"), ("the", "merrier"),
("more", "the"), ("more", "merrier"), ("the", "merrier")
</c>
</p>

<activity label="frq2018-WordPair-A">
<statement>
<p>
Complete the WordPairList constructor below.      
</p>
</statement>
<program interactive="activecode" language="java">
<code>
import java.util.ArrayList;

public class WordPairList
{
    /** The list of word pairs, initialized by the constructor. */
    private ArrayList&lt;WordPair&gt; allPairs;

    /** Constructs a WordPairList object as described in part (a).
     * Precondition: words.length &gt;= 2
     */
    public WordPairList(String[] words)
    { 
        /* to be implemented in part (a) */ 
    }

    public static void main(String[] args) 
    {
        String[] wordNums = {"one", "two", "three"};
        WordPairList exampleOne = new WordPairList(wordNums);

        System.out.println("Example 1 should be: [(one, two), (one, three), (two, three)]");
        System.out.println(exampleOne);

        String[] phrase = {"the", "more", "the", "merrier"};
        WordPairList exampleTwo = new WordPairList(phrase);

        System.out.println("Example 2 should be: [(the, more), (the, the), (the, merrier), (more, the), (more, merrier), (the, merrier)]");
        System.out.println(exampleTwo);

        String[] moreWords = {"the", "red", "fox", "the", "red"};
        WordPairList exampleThree = new WordPairList(moreWords);

        System.out.println("Example 3 should be: [(the, red), (the, fox), (the, the), (the, red), (red, fox), (red, the), (red, red), (fox, the), (fox, red), (the, red)]");
        System.out.println(exampleThree);
    }

    public String toString()
    {
        if (allPairs == null)
            return "ArrayList is null";
        return allPairs.toString();
    }
}

class WordPair
{
    /** Constructs a WordPair object. */
    public WordPair(String first, String second)
    {
        this.first = first;
        this.second = second;
    }

    /** Returns the first string of this WordPair object. */
    public String getFirst()
    { return first; }

    /** Returns the second string of this WordPair object. */
    public String getSecond()
    { return second; }

    public String toString() {
        return "(" + first + ", " + second + ")";
    }

    private String first, second;
}
</code>
<tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;
import java.util.Arrays;

public class RunestoneTests extends CodeTestHelper
{
    @Test
    public void test01A() {
        String[] words = "hello world code runs fast".split(" ");
        String expect = "[(hello, world), (hello, code), (hello, runs), (hello, fast), (world, code), (world, runs), (world, fast), (code, runs), (code, fast), (runs, fast)]";
        
        boolean passed = testA(words, expect);
        assertTrue(passed);        
    }
    
    @Test
    public void test02A() {
        String[] words = "never say never again".split(" ");
        String expect = "[(never, say), (never, never), (never, again), (say, never), (say, again), (never, again)]";
        
        boolean passed = testA(words, expect);
        assertTrue(passed);        
    }
    
    @Test
    public void test03A() {
        String[] words = "duck duck duck goose".split(" ");
        String expect = "[(duck, duck), (duck, duck), (duck, goose), (duck, duck), (duck, goose), (duck, goose)]";
        
        boolean passed = testA(words, expect);
        assertTrue(passed);        
    }
    
    @Test
    public void test04A() {
        String[] words = "duck duck duck goose goose".split(" ");
        String expect = "    [(duck, duck), (duck, duck), (duck, goose), (duck, goose), (duck, duck), (duck, goose), (duck, goose), (duck, goose), (duck, goose), (goose, goose)]";
        
        boolean passed = testA(words, expect);
        assertTrue(passed);        
    }

    private boolean testA(String[] words, String expect) {
        String desc = "Part (a) for " + Arrays.toString(words);
        String expected = "" + expect;
        String actual = "";
        
        
        try {
            WordPairList exampleOne = new WordPairList(words);
            actual += exampleOne.toString();
        } catch (Exception e) {
            actual = "Code caused an error";
        }

        boolean passed = getResults(expected, actual, desc);        
        return passed;
    }
}
