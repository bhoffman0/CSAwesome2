import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;
import java.util.Arrays;

public class RunestoneTests extends CodeTestHelper
{
    int[] input = {};
    int[] output = {};    

    @Test
    public void test01() {
        boolean[] results = {false, false, true, false, false, false, false, true, false, true};

        boolean passed = test(results, 0.3);
        assertTrue(passed);       
    }

    @Test
    public void test02() {
        boolean[] results = {false, true, false, false, true, false, true, false, true, true};

        boolean passed = test(results, 0.5);
        assertTrue(passed);         
    }

    @Test
    public void test03() {
        boolean[] results = {true, false, true, false, false, false, false, false, false, false};

        boolean passed = test(results, 0.2);
        assertTrue(passed);      
    }

    @Test
    public void test04() {
        boolean[] results = {true, true, true, true, true, true, false, true, false, false};

        boolean passed = test(results, 0.7);
        assertTrue(passed);     
    }

    @Test
    public void test05() {
        boolean[] results = {false, true, false, false, true, false, true, false, true, false};

        boolean passed = test(results, 0.4);
        assertTrue(passed);        
    }

    private boolean test(boolean[] results, double exp) {
        String desc = "Part (b) for simulation results: " + Arrays.toString(results);
        String expected = "" + exp;
        String actual = "";

        try {
            FrogSimulation sim = new FrogSimulation(0, 0);
            sim.setResults(results);
            actual += sim.runSimulations(10);
        } catch (Exception e) {
            actual = "Code caused an error";
        }

        boolean passed = getResults(expected, actual, desc);        
        return passed;
    }
}
