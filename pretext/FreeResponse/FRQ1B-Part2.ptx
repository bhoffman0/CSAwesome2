<subsection xml:id="frq1b2-maskvowels">
<title>String Algorithm - Mask Vowels</title>

<activity label="frq1b2-maskvowels">
<statement>
<p>Write a method called maskVowels that takes a String and returns a new String where all vowels are replaced with asterisks (*), but only if the String is longer than 3 letters.</p>
</statement>

<program interactive="activecode" language="java">
<code>
public class WordTransformer {
    public static String maskVowels(String word) {
        
    }

    public static boolean isVowel(String letter) {
        String vowels = "aeiouAEIOU";
        return letter.length() == 1 &amp;&amp; vowels.contains(letter);
    }

    public static void main(String[] args) {
        // Test 1: Standard lowercase word
        String w1 = "computer";
        System.out.println("Input: " + w1);
        System.out.println("Result: " + WordTransformer.maskVowels(w1)); // Expected: c*mp*t*r
        System.out.println();

        // Test 2: Word with uppercase vowels
        String w2 = "ALPHABET";
        System.out.println("Input: " + w2);
        System.out.println("Result: " + WordTransformer.maskVowels(w2)); // Expected: *LPH*B*T
        System.out.println();

        // Test 3: Word too short (less than 3 chars)
        String w3 = "it";
        System.out.println("Input: " + w3);
        System.out.println("Result: " + WordTransformer.maskVowels(w3)); // Expected: it
    }
}

</code>
<tests>
