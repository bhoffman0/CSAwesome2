<subsection xml:id="frq1b1-tagparser">
<title>String Method - Tag Parser</title>

<activity label="frq1b1-tagparser">
<statement>
<p>A common task is extracting text between two delimiters (like HTML tags). Uses indexOf to find the start and end and substring to grab what's in the middle. Return "not found" if the the tags are not found, not balanced, or backwards</p>
</statement>

<program interactive="activecode" language="java">
<code>
public class TagParser {
    public static String getContent(String html) {
        
    }
    
    public static void main(String[] args) {
        // Test 1: Standard case
        String html1 = "&lt;p&gt;Hello World&lt;/p&gt;";
        System.out.println("Test 1: " + html1);
        System.out.println("Result: " + TagParser.getContent(html1));
        System.out.println();

        // Test 2: Text before and after the tags
        String html2 = "Body text: &lt;p&gt;Important Info&lt;/p&gt; Footer";
        System.out.println("Test 2: " + html2);
        System.out.println("Result: " + TagParser.getContent(html2));
        System.out.println();

        // Test 3: Tag order reversed (Edge Case)
        String html3 = "&lt;/p&gt;Wrong Order&lt;p&gt;";
        System.out.println("Test 3: " + html3);
        System.out.println("Result: " + TagParser.getContent(html3));
    }
}
</code>
<tests>
import static org.junit.Assert.*;
import org.junit.*;
import java.io.*;

public class RunestoneTests extends CodeTestHelper
{
    private String[] input = {"&lt;p&gt;Success&lt;/p&gt;", "&lt;p&gt;No closing tag", "No opening tag&lt;/p&gt;", "&lt;/p&gt;Bad order&lt;p&gt;", "&lt;p&gt;&lt;/p&gt;"};
    private String[] expected = {"Success", "not found", "not found", "not found", ""};

    @Test
    public void test0() {
        boolean passed = test(0);
        assertTrue(passed);
    }

    @Test
    public void test1() {
        boolean passed = test(1);
        assertTrue(passed);
    }

    @Test
    public void test2() {
        boolean passed = test(2);
        assertTrue(passed);
    }

    @Test
    public void test3() {
        boolean passed = test(3);
        assertTrue(passed);
    }

    @Test
    public void test4() {
        boolean passed = test(4);
        assertTrue(passed);
    }

    private boolean test(int i) {
        String desc = "getContent(\"" + input[i] + "\")";
        String actual = "";

        try {
            actual = TagParser.getContent(input[i]);
        } catch (Exception e) {
            actual = "The code caused an exception";
        }

        boolean passed = getResults(expected[i],actual,desc);
        return passed;        
    }

    private boolean stringMatch(String str1, String str2) {
        str1 = str1.replaceAll(" ", "");
        str2 = str2.replaceAll(" ", "");

        return str1.contains(str2);
    }
}
</tests>
</program>
</activity>

