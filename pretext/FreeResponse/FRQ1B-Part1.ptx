<subsection xml:id="frq1b1-swapstrings">
<title>String Method - Swap Strings</title>

<activity label="frq1b1-swapstrings">
<statement>
<p>This class takes a two-word string (separated by a space) and returns a new string where the words are swapped. Use indexOf to find the pivot point and length() to ensure there is actually a second word.</p>
</statement>

<program interactive="activecode" language="java">
<code>
public class StringScrambler {
    public static String swapTwoWords(String phrase) {

    }
    

    public static void main(String[] args) {
        // Test 1: Standard two-word phrase
        String p1 = "Hello World";
        System.out.println("Input: " + p1);
        System.out.println("Result: " + StringScrambler.swapTwoWords(p1));
        System.out.println();

        // Test 2: Different word lengths
        String p2 = "Java Programming";
        System.out.println("Input: " + p2);
        System.out.println("Result: " + StringScrambler.swapTwoWords(p2));
        System.out.println();

        // Test 3: Single word (No space)
        String p3 = "Computer";
        System.out.println("Input: " + p3);
        System.out.println("Result: " + StringScrambler.swapTwoWords(p3));
    }
}
</code>
<tests>
