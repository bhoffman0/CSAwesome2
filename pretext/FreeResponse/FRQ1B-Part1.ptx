<subsection xml:id="frq1b1-createusername">
<title>String Method - Create User Name</title>

<activity label="frq1b1-createusername">
<statement>
<p>This class creates a username by taking the first letter of the first name and the first five letters of the last name. It uses an if statement to handle cases where the last name is shorter than five characters.</p>
</statement>

<program interactive="activecode" language="java">
<code>
public class UserProfile {
    public static String createHandle(String firstName, String lastName) {
        
    }
    
    public static void main(String[] args) {
        // Example 1: Standard names
        System.out.println("Input: Charles, Babbage");
        System.out.println("Handle: " + UserProfile.createHandle("Charles", "Babbage"));
        System.out.println();

        // Example 2: Last name exactly 5 characters
        System.out.println("Input: Margaret, Hamil");
        System.out.println("Handle: " + UserProfile.createHandle("Margaret", "Hamil"));
        System.out.println();

        // Example 3: Very short last name
        System.out.println("Input: Alan, Tu");
        System.out.println("Handle: " + UserProfile.createHandle("Alan", "Tu"));
    }
}

</code>
<tests>
