      {
          String code = getCode();
          int num = countOccurences(code, "Math.PI");

          boolean passed = num &amp;gt;= 4;
          getResults("4 times", num + " times", "Used Math.PI correct number of times", passed);
          assertTrue(passed);
      }

      @Test
