<subsection xml:id="unit1b-project3">
   <title>Unit 1B Project 3 - String Program</title>

   <p>
    <term>StringProgram</term>
   </p>
<p>
Write a program that reads in a single String from the user containing exactly four words separated by symbols with no spaces into a single String object. Next, extract each word from the original string and store each word in a String object. Then, concatenate the words in reverse order to form another string. Display both the original and final strings.  
</p>
<p>
  Hint: to extract the words, you should use the indexOf ( ) method to find each symbol and then use the substring ( ) method to get the characters between the * symbols.
</p>
<p>
  Example output:
</p>
<pre>
Original: one*two*three*four
Reverse: four three two one
</pre>

      <activity label="unit1b-project3-stringprogram">
      <statement>
        <p></p>
      </statement>

      <program interactive="activecode" language="java">
        <code>
import java.util.Scanner;

public class StringProgram{
  public static void main(String[] args)
  {

  }
}

        </code>
        <stdin>This*code*works*well</stdin>
        <tests>
  import static org.junit.Assert.*;
  import org.junit.*;
  import java.io.*;

  public class RunestoneTests extends CodeTestHelper
  {
      public RunestoneTests() {
          //super("Main", input1.replaceAll(" ", "\n")); // For Book
          //super("StringProgram", input1.replaceAll(" ", "\n")); // For Repl.it
      }


      private static String input1 = "This*code*works*well";
      private static String input2 = "Am*I*correct*now?";
      private static String input3 = "This*Is*A*Test";


      @Test
      public void test1()
      {
          String input = input1.replaceAll(" ", "\n");
          String output = getMethodOutputWithInput("main", input);
          String actual = "No matching lines";
          String expect = "well works code This";
          boolean passed = false;

          String[] lines = output.split("\n");

          for (String line: lines) {
              if (line.contains(expect)) {
                  passed = true;
                  actual = line;
                  break;
              }
          }


          getResults(expect, actual, "Expected output for input " + input1, passed);
          assertTrue(passed);
      }

      @Test
          public void test2()
          {
              String input = input2.replaceAll(" ", "\n");
              String output = getMethodOutputWithInput("main", input);
              String actual = "No matching lines";
              String expect = "now? correct I Am";
              boolean passed = false;

              String[] lines = output.split("\n");

              for (String line: lines) {
                  if (line.contains(expect)) {
                      passed = true;
                      actual = line;
                      break;
                  }
              }


              getResults(expect, actual, "Expected output for input " + input2, passed);
              assertTrue(passed);
          }

      @Test
      public void test3()
      {
          String code = getCode();
          boolean created = countOccurences(code, "new Scanner(System.in)") == 1;
          int num = countOccurences(code, ".nextLine()");
          boolean called = num == 1;

          String output = "Created: " + created + "\nMethod Called: " + true;
          String expected = "Created: " + true + "\nMethod Called: " + called;

          boolean passed = created &amp;&amp; called;
          getResults(expected, output, "Used Scanner correctly", passed);
          assertTrue(passed);
      }

      @Test
      public void test4()
      {
          String code = getCode();
          int num = countOccurences(code, ".indexOf(");

          boolean passed = num &gt;= 3;
          getResults("3 times", num + " times", "Called indexOf(\"*\")", passed);
          assertTrue(passed);
      }

      @Test
      public void test5()
      {
          String code = getCode();
          int num = countOccurences(code, ".substring(");

          boolean passed = num &gt;= 4;
          getResults("4+ times", num + " times", "Called substring(...)", passed);
          assertTrue(passed);
      }

      @Test
      public void test6()
      {
          String code = getCode();
          int num = countOccurences(code, "System.out.print");

          boolean passed = num &gt;= 3;
          getResults("3+ times", num + " times", "Called System.out.print[ln](...) at least 3 times", passed);
          assertTrue(passed);
      }

      @Test
      public void test7()
      {
          String code = getCode();
          int num = 0;

          String[] lines = code.split("\n");

          for (String line : lines){
              if (line.contains("String") &amp;&amp; !line.contains("main") &amp;&amp; !line.contains("class")) {
                  if (line.contains(",")) {
                      num += line.split(",").length;
                  } else {
                      num++;
                  }
              }
          }

          boolean passed = num &gt;= 4;
          getResults("4+", num + "", "Created at least four String variables", passed);
          assertTrue(passed);
      }

      @Test
      public void test8()
      {
          String code = getCode();
          int num = 0;

          String[] lines = code.split("\n");

          for (String line : lines){
              if (line.contains("int ")) {
                  if (line.contains(",")) {
                      num += line.split(",").length;
                  } else {
                      num++;
                  }
              }
          }

          boolean passed = num &gt;= 1;
          getResults("1+", num + "", "Created at least one int variable", passed);
          assertTrue(passed);
      }

      @Test
