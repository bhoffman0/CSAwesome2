  import static org.junit.Assert.*;
  import org.junit.*;
  import java.io.*;

  public class RunestoneTests extends CodeTestHelper
  {
      public RunestoneTests() {
          //super("Main", input1.replaceAll(" ", "\n")); // For Book
          //super("RoundThingsDriver", input3.replaceAll(" ", "\n")); // For Repl.it

          radius = (int) (Math.random() * 10 + 5);
      }

      private static String input1 = "5.0";
      private static String input2 = "7.0";
      private static String input3 = "10.0";

      private double radius;


      @Test
      public void test1()
      {
          String input = input1.replaceAll(" ", "\n");
          String output = getMethodOutputWithInput("main", input);

          String expect = "area = 78.53981633, circumference = 31.415926, surface area = 314.15926, volume = 523.59877".replaceAll(", ","\n");

          boolean passed = output.contains("78.53981633");
          passed = passed &amp;&amp; output.contains("31.415926");
          passed = passed &amp;&amp; output.contains("314.15926");
          passed = passed &amp;&amp; output.contains("523.59877");

          getResults(expect, output, "Expected calculation for input " + input1, passed);
          assertTrue(passed);
      }

      @Test
      public void test2()
      {
          String input = input2.replaceAll(" ", "\n");
          String output = getMethodOutputWithInput("main", input);

          String expect = "area = 153.93804, circumference = 43.982297, surface area = 615.75216, volume = 1436.75504".replaceAll(", ","\n");

          boolean passed = output.contains("153.93804");
          passed = passed &amp;&amp; output.contains("43.982297");
          passed = passed &amp;&amp; output.contains("615.75216");
          passed = passed &amp;&amp; output.contains("1436.75504");

          getResults(expect, output, "Expected calculation for input " + input2, passed);
          assertTrue(passed);
      }


      @Test
      public void test3()
      {
          String code = getCode();
          int num = countOccurences(code, "class RoundThings");

          boolean passed = num == 2;
          getResults("Classes: " + 2, "Classes: " + num, "Two classes created", passed);
          assertTrue(passed);
      }

      @Test
      public void test4()
      {
          String code = getCode();
          int num = countOccurences(code, "public static double");
          String output = "public static double methods: " + num;
          String expect = "public static double methods: " + 4;

          boolean passed = num == 4;
          getResults(expect, output, "4 static double methods created", passed);
          assertTrue(passed);
      }

      @Test
      public void test5()
      {
          String code = getCode();
          boolean created = countOccurences(code, "new Scanner(System.in)") == 1;
          int num = countOccurences(code, ".nextDouble()");
          boolean called = num == 1;

          String output = "Created: " + created + "\nCalled: " + num + " time";
          String expected = "Created: " + true + "\nCalled: " + 1 + " time";

          boolean passed = created &amp;&amp; called;
          getResults(expected, output, "Used Scanner correctly", passed);
          assertTrue(passed);
      }



      @Test
      public void test6()
      {
          String code = getCode();
          int param = -1;
          String header = "no header found";

          String[] lines = code.split("\n");

          for (String line: lines) {
              if (line.contains("static") &amp;&amp; line.contains("outPut")) {
                  param = numParameters(line);
                  header = line;
                  break;
              }
          }

          boolean passed = param == 4 &amp;&amp; !header.equals("no header found");

          String output = header + " (" + param + ")";
          String expect = "public static void outPut (...) (4 parameters)";

          getResults(expect, output, "outPut method declared properly with four parameters", passed);
          assertTrue(passed);
      }

      private int numParameters(String line) {
          if(line.contains("(") &amp;&amp; line.contains(")")) {
              line = line.substring(line.indexOf("(") + 1, line.indexOf(")"));
              return line.split(",").length;
          }
          return 0;
      }

      @Test
      public void test7() {
          String code = getCode();
          int num = 0;

          String[] lines = code.split("\n");

          for (String line: lines) {
              if (line.contains("outPut") &amp;&amp; !line.contains("static")) {
                  if (numParameters(line) == 4) {
                      num++;
                  }
              }
          }

          boolean passed = num == 4;
          getResults("4 times", num + " times", "Called outPut method 4 times", passed);
          assertTrue(passed);
      }

      @Test
