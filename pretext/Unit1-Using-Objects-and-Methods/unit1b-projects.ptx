          for (String line : lines){
              if (line.contains("\"") &amp;&amp; line.contains("+")) {
                  output = line;
                  passed = true;
              }
          }
          getResults("\"...\" + \"...\"", output, "Used String concatenation", passed);
          assertTrue(passed);
      }

      @Test
      public void test10()
      {
          String input = input3.replaceAll(" ", "\n");
          String output = getMethodOutputWithInput("main", input);
          String actual = "No matching lines";
          String expect = "Test A Is This";
          boolean passed = false;

          String[] lines = output.split("\n");

          if (lines.length &gt; 1)
              actual = lines[lines.length-1];

          passed = !actual.contains("*") &amp;&amp; actual.contains(" ") &amp;&amp; !actual.equals("No matching lines");
          getResults(expect, actual, "Reverse String has spaces instead of astericks", passed);
          assertTrue(passed);
      }

  }

        </tests>
      </program>
