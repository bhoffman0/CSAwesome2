      {
          String code = getCode();
          int num = countOccurences(code, "System.out.print");

          boolean passed = num &amp;lt;= 2 &amp;&amp; num &amp;gt; 0;
          getResults("2 times", num + " times", "Called System.out.print[ln](...) 2 times maximum", passed);
          assertTrue(passed);
      }


  }

