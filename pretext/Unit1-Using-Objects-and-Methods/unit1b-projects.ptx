        <stdin>4.0 5.0</stdin>
        <tests>
  import static org.junit.Assert.*;
  import org.junit.*;
  import java.io.*;

  public class RunestoneTests extends CodeTestHelper
  {
      public RunestoneTests() {
          //super("Main", input1.replaceAll(" ", "\n")); // For Book
          //super("MyShape", input3.replaceAll(" ", "\n")); // For Repl.it

          length = (int) (Math.random() * 10 + 5);
          width = (int) (Math.random() * 10 + 5);
      }

      private static int goal = 1;
      private static String input1 = "4.0 5.0";
      private static String input2 = "10.0 3.0";
      private static String input3 = "2.0 3.0";
      private String output1, output2;

      private double length, width;


      @Test
      public void test1()
      {
          String input = input1.replaceAll(" ", "\n");
          String output = getMethodOutputWithInput("main", input);

          String expect = "Perimeter = 18.0\nArea = 20.0";

          boolean passed = output.contains("18.0") &amp;&amp; output.contains("20.0") ;

          getResults(expect, output, "Expected calculation for inputs " + input1, passed);
          assertTrue(passed);
      }

      @Test
      public void test2()
      {
          String input = input2.replaceAll(" ", "\n");
          String output = getMethodOutputWithInput("main", input);

          String expect = "Perimeter = 26.0\nArea = 30.0";

          boolean passed = output.contains("26.0") &amp;&amp; output.contains("30.0") ;

          getResults(expect, output, "Expected calculation for inputs " + input2, passed);
          assertTrue(passed);
      }


      @Test
      public void test3()
      {
          String code = getCode();
          boolean created = countOccurences(code, "new Scanner(System.in)") == 1;
          int num = countOccurences(code, ".nextDouble()");
          boolean called = num == 2;

          String output = "Created: " + created + "\nCalled: " + num + " times";
          String expected = "Created: " + true + "\nCalled: " + 2 + " times";

          boolean passed = created &amp;&amp; called;
          getResults(expected, output, "Used Scanner correctly", passed);
          assertTrue(passed);
      }

      @Test
      public void test4()
      {
          String code = getCode();
          String output = "no matching method declared";
          String expect = "static void perimeter(...)";
          boolean passed = false;

          String[] lines = code.split("\n");

          for (String line: lines) {
              if (line.contains("public") &amp;&amp; line.contains("perimeter")) {
                  output = line;
                  if (line.contains("static void perimeter")) {
                      passed = true;
                      break;
                  }
              }
          }


          getResults(expect, output, "Perimeter method declared properly", passed);
          assertTrue(passed);
      }

      @Test
      public void test5()
      {
          String code = getCode();
          boolean header = false, ret = false;
          String hdr = "none", retn = "none";

          String[] lines = code.split("\n");

          for (String line : lines) {
              if (line.contains("public") &amp;&amp; line.contains("area")) {
                  if (line.contains("static double area")) {
                      header = true;
                      hdr = line;
                  }
              }
              if (line.contains("return")) {
                  ret = true;
                  retn = line;
              }
          }

          boolean passed = header &amp;&amp; ret;

          String output = "Header: " + hdr + "\nReturn: " + retn;
          String expect = "Header: public static double area(double l, double w)" + "\nReturn: " + "return l * w;";

          getResults(expect, output, "Area method declared properly and returns a value", passed);
          assertTrue(passed);
      }

      @Test
      public void test6()
      {
          String code = getCode();
          int area = -1, perimeter = -1;
          String areaH = "none", perimH = "none";

          String[] lines = code.split("\n");

          for (String line: lines) {
              if (line.contains("public") &amp;&amp; line.contains("area")) {
                  area = numParameters(line);
                  areaH = line;
              }
              if (line.contains("public") &amp;&amp; line.contains("perimeter")) {
                  perimeter = numParameters(line);
                  perimH = line;
              }
          }

          boolean passed = area == 2 &amp;&amp; perimeter == 2;

          String output = "Perimeter: " + perimH + " (" + perimeter + " parameters)\nArea: " + areaH + " (" + area + " parameters)";
          String expect = "Perimeter: perimeter(double l, double w)\nArea: area(double l, double w)";

          getResults(expect, output, "Methods both have 2 parameters each", passed);
          assertTrue(passed);
      }

      private int numParameters(String line) {
          if(line.contains("(") &amp;&amp; line.contains(")")) {
              line = line.substring(line.indexOf("(") + 1, line.indexOf(")"));
              return line.split(",").length;
          }
          return 0;
      }

      @Test
      public void test7()
      {
          String code = getCode();
          String area = "none", perimeter = "none";
          int areaNum = -1, perimNum = -1;

          String[] lines = code.split("\n");

          for (String line: lines) {
              if (line.contains("area") &amp;&amp; !line.contains("static") &amp;&amp; !line.contains("System")) {
                  area = line;
                  areaNum = numParameters(line);
              }
              if (perimeter == "none" &amp;&amp; line.contains("perimeter") &amp;&amp; !line.contains("static")  &amp;&amp; !line.contains("System")) {
                  perimeter = line;
                  perimNum = numParameters(line);
              }
          }

          boolean passed = areaNum == 2 &amp;&amp; perimNum == 2;

          String output = "Perimeter: " + perimeter + " (" + perimNum + " parameters)\nArea: " + area + " (" + areaNum + " parameters)";
          String expect = "Perimeter: perimeter(length, width) (2 parameters)\nArea: area(length, width) (2 parameters)";

          getResults(expect, output, "Perimeter and Area methods have been called properly", passed);
          assertTrue(passed);
      }


      @Test
      public void test8()
      {
          String code = getCode();
          int num = countOccurences(code, "System.out.println(");

          boolean passed = num &amp;amp;gt;= 2;
          getResults("2 times", num + " times", "Called System.out.println(...) enough times", passed);
          assertTrue(passed);
      }

     @Test
      public void test9() {
          Object[] args = {length, width};
          String ans = getMethodOutput("perimeter", args);
          double exp = 2 * length + 2 * width;

          boolean passed = getResults("" + exp, "" + ans, "Correct calculation for perimeter with inputs " + length + " and " + width);
          assertTrue(passed);
      }

      @Test
      public void test10() {
          Object[] args = {length, width};
          String ans = getMethodOutput("area", args);
          double exp = length * width;

          boolean passed = getResults("" + exp, "" + ans, "Correct calculation for area with inputs " + length + " and " + width);
          assertTrue(passed);
      }
  }

        </tests>
      </program>
    </activity>

