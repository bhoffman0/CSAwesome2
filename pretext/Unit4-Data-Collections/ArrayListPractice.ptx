              import static org.junit.Assert.*;

              import org.junit.*;

              import java.io.*;
              import java.util.ArrayList;

              public class RunestoneTests extends CodeTestHelper
              {
                  @Test
                  public void testMain() throws IOException
                  {
                      String output = getMethodOutput("main");
