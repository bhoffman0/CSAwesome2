                      assertTrue(passed);
                  }

                  @Test
                  public void testSumNegValues()
                  {
                      ArrayList&lt;Integer&gt; values = new ArrayList&lt;Integer&gt;();
                      values.add(2);
                      values.add(34);
                      values.add(-10);
                      values.add(9);
                      values.add(-5);
                      values.add(3);

                      String output = String.valueOf(Test1.sumNegValues(values));
